<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#131A26"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[!] THREAT DETECTED"
        android:textColor="#FF1744"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INCOMING TRANSMISSION"
        android:textColor="#00E5FF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvIncomingNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+1 000 000 0000"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvAlertDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="> Analyzing call signature...\n> Anomaly detected in routing prefix."
        android:textColor="#8892B0"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btnReject"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SEVER CONNECTION (REJECT)"
            android:backgroundTint="#FF1744"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="BYPASS WARNING (ACCEPT)"
            android:backgroundTint="#192231"
            android:textColor="#8892B0"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
